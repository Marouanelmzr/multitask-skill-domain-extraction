    "import torch\n",
    "from torch.optim import AdamW\n",
    "\n",
    "optimizer = AdamW(model.parameters(), lr= 2e-5)\n",
    "# No loss here because in the models class for each classifier head we define a different loss"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "GUSjplqIjzQn",
   "metadata": {
    "id": "GUSjplqIjzQn"
